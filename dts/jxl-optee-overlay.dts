/*
 * Linux DTB overlay that adds the OP-TEE firmware node so the Linux optee
 * driver binds. Applied on top of jxl-linux.dtb (or jxl-xen.dtb) only by
 * the jxl-optee / jxl-xen-optee start.sh modes, so the base DTB used by
 * non-OP-TEE chains (jxl-linux, jxl-xen, jxl-xen-atf, ...) stays untouched.
 */

/dts-v1/;
/plugin/;

/ {
	fragment@0 {
		target-path = "/";

		__overlay__ {
			firmware {
				optee {
					compatible = "linaro,optee-tz";
					method = "smc";
					/*
					 * OP-TEE async notification IRQ. CFG_CORE_ASYNC_NOTIF_GIC_INTID
					 * is 219 (= SPI 187 + 32 SGI/PPI base) in
					 * core/arch/arm/plat-vexpress/conf.mk for the jxl flavor.
					 * Without this the Linux optee driver fails probe with
					 * `IRQ index 0 not found` and /dev/tee0 never appears.
					 */
					interrupts = <0 187 4>;
				};
			};
		};
	};
};
